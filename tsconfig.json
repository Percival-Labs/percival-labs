{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@percival/shared": ["./packages/shared/src/index.ts"],
      "@percival/shared/*": ["./packages/shared/src/*"],
      "@percival/db": ["./packages/db/src/index.ts"],
      "@percival/db/*": ["./packages/db/src/*"],
      "@percival/agent-memory": ["./packages/agent-memory/src/index.ts"],
      "@percival/agent-memory/*": ["./packages/agent-memory/src/*"]
    }
  }
}
