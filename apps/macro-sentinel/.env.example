# Macro Sentinel Configuration
SENTINEL_PORT=3800
SENTINEL_MODE=paper

# TradingView webhook auth
TV_WEBHOOK_PASSPHRASE=change-me-to-something-random

# Alpaca (paper trading - get keys at https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# FRED (free - get key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Database
SENTINEL_DB_PATH=./data/sentinel.db
