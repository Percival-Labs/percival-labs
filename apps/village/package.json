{
  "name": "@percival/village",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun run --watch src/server/index.ts",
    "dev:client": "vite --config vite.config.ts",
    "build:client": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
