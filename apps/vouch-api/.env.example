# Database
DATABASE_URL=postgresql://percival:percival-local-dev@localhost:5432/vouch

# Alby Hub (platform Lightning node)
ALBY_HUB_URL=http://localhost:8080
ALBY_HUB_JWT=<jwt-token-from-alby-hub-setup>

# Encryption (AES-256-GCM for NWC connection strings at rest)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<64-char-hex-string>

# CORS origins (comma-separated)
VOUCH_CORS_ORIGINS=http://localhost:3600

# ERC-8004 (optional)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# PL Treasury Auto-Staking (optional — sensible defaults)
# PL_STAKER_ID=pl-treasury
# PL_OPERATING_RESERVE_SATS=50000
# PL_MAX_POOL_CONCENTRATION_BPS=2000
# PL_EXTRACTION_THRESHOLD_SATS=10000000
