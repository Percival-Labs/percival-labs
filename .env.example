# Percival Labs — Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# Anthropic API key for agent team
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Discord Bot
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=YOUR_GUILD_ID

# Separate Anthropic key for Discord bot (optional — falls back to ANTHROPIC_API_KEY)
PERCIVAL_API_KEY=sk-ant-api03-YOUR_PERCIVAL_KEY_HERE

# Internal service auth (generate with: openssl rand -hex 32)
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32
AGENTS_API_KEY=GENERATE_WITH_openssl_rand_hex_32

# OpenRouter — multi-model routing (single key for Claude, GPT, Gemini, Grok, Llama, DeepSeek)
OPENROUTER_API_KEY=sk-or-YOUR_OPENROUTER_KEY_HERE

# OpenClaw — chaos agent gateway
OPENCLAW_TOKEN=GENERATE_WITH_openssl_rand_hex_32

# X/Twitter API (@PercivalLabs)
TWITTER_API_KEY=YOUR_TWITTER_API_KEY
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_ACCESS_TOKEN
TWITTER_ACCESS_TOKEN_SECRET=YOUR_TWITTER_ACCESS_TOKEN_SECRET
